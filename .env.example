# ── Server ────────────────────────────────────────────────────────
PORT=3000

# ── Email (Gmail) ─────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password (select "Mail" + "Other")
# 4. Paste the 16-char password below (no spaces)
EMAIL_FROM=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-password-here

# ── SMS (Twilio) ───────────────────────────────────────────────────
# 1. Sign up free at https://www.twilio.com/
# 2. Get a phone number (free trial number works)
# 3. Copy Account SID, Auth Token, and the Twilio phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
